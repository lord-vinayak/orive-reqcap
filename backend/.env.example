# ============================================
# Django Backend Environment Variables
# Copy this file to .env and fill in real values
# ============================================

# --- Django Core ---
SECRET_KEY=replace-with-a-long-random-string-50-chars-or-more
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# --- Database (Supabase PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Get this from Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# --- CORS (Frontend URL) ---
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# --- Google OAuth (for "Sign in with Google") ---
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Drive Service Account ---
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Download the JSON key file, then either:
#   (a) Paste the entire JSON content here (as one line), OR
#   (b) Set GOOGLE_DRIVE_CREDENTIALS_FILE to the path of the JSON file
GOOGLE_DRIVE_CREDENTIALS_JSON=
GOOGLE_DRIVE_CREDENTIALS_FILE=

# The root Google Drive folder ID where all files will be uploaded
# Share this folder with the service account email (xxxxx@xxxxx.iam.gserviceaccount.com)
# Get the folder ID from the Drive folder URL: https://drive.google.com/drive/folders/THIS_IS_THE_ID
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# --- Groq API (for audio transcript extraction) ---
# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- JWT Settings ---
JWT_SIGNING_KEY=replace-with-another-long-random-string

# --- Email/Password Auth ---
# When Admin creates a new user with email/password, this is the default password they get
# (User can change it on first login)
DEFAULT_NEW_USER_PASSWORD=ChangeMe123!

# --- Admin bootstrap (auto-create initial admin user on first run) ---
INITIAL_ADMIN_EMAIL=admin@skinovationsciences.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!
INITIAL_ADMIN_NAME=Admin User
